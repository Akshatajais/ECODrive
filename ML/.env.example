# Copy to .env and fill values.
# Never commit real secrets (service account JSON, private keys).

# --- Option 1 (recommended): Use a Firebase service account JSON file ---
FIREBASE_SERVICE_ACCOUNT_JSON=/absolute/path/to/serviceAccountKey.json

# Firebase Realtime Database URL, e.g. https://<project-id>-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=

# Root path in RTDB containing the nested history data.
# For your schema: carEmissions/history
FIREBASE_HISTORY_PATH=carEmissions/history

# Optional: cache downloaded history to a local JSON file so you can iterate faster
FIREBASE_CACHE_JSON=./data/firebase_history_cache.json

# Random seed for reproducibility
ECODRIVE_SEED=42
