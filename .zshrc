export PATH="/Library/Frameworks/Python.framework/Versions/3.13/bin:$PATH"

export PATH="$PATH:/Users/akshata/Desktop/Mobile Dev/sdk/flutter/bin"

export JAVA_HOME=$(/usr/libexec/java_home -v 22.0.2)
export PATH=$JAVA_HOME/bin:$PATH
alias python='python3'
alias flutter17="export JAVA_HOME=/opt/homebrew/opt/openjdk@17 && export PATH=\$JAVA_HOME/bin:\$PATH && flutter"
export ANDROID_HOME=$HOME/Library/Android/sdk
export ANDROID_SDK_ROOT=$ANDROID_HOME
export PATH=$ANDROID_HOME/emulator:$ANDROID_HOME/tools:$ANDROID_HOME/platform-tools:$PATH
export PATH="$PATH":"$HOME/.pub-cache/bin"






